# ── Backend API ────────────────────────────────────────────────────
# Base URL for all data API calls (axios client)
VITE_API_BASE_URL=http://localhost:8080/api

# ── Authentik (OIDC / OAuth2) ──────────────────────────────────────
# Your Authentik instance base URL  e.g. https://auth.nsdl.co.in
VITE_AUTH_BASE_URL=https://your-authentik.example.com

# OAuth2 client credentials (create an Application in Authentik)
VITE_AUTH_CLIENT_ID=nsdl-admin
VITE_AUTH_CLIENT_SECRET=your-client-secret-here

# ── App ────────────────────────────────────────────────────────────
VITE_APP_TITLE=NSDL CBC Admin
